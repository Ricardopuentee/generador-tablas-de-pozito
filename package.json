{
  "name": "generador-tablas-loteria",
  "productName": "Generador de Tablas de Loteria",
  "version": "1.0.0",
  "description": "App de escritorio para generar tablas de loteria listas para imprimir y descargar.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "build:win": "electron-builder --win --x64"
  },
  "dependencies": {
    "html2canvas": "^1.4.1",
    "jimp": "^1.6.1",
    "jsdom": "^29.0.2"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.tablasloteria.generador",
    "artifactName": "Generador-Tablas-Loteria-${version}-Windows-${arch}.${ext}",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Generador de Tablas de Loteria"
    },
    "files": [
      "index.html",
      "main.js",
      "preload.js",
      "package.json",
      "Baraja de loteria optimizada/**/*",
      "Baraja estilizada/**/*",
      "Baraja \"Grande\"/**/*",
      "baraja animada/**/*",
      "cartas_recortadas/**/*",
      "template.png",
      "node_modules/html2canvas/dist/html2canvas.min.js"
    ]
  }
}
